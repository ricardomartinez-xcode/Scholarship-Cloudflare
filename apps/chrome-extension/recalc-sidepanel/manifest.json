{
  "update_url": "https://clients2.google.com/service/update2/crx",
  "manifest_version": 3,
  "name": "ReCalc Sender",
  "version": "6.3.4",
  "description": "Extensión ReCalc Sender 6.3.4 para campañas WhatsApp Web con envío de imágenes como foto/video y caption, no sticker.",
  "minimum_chrome_version": "114",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "tabs",
    "alarms",
    "scripting",
    "activeTab",
    "debugger",
    "downloads"
  ],
  "host_permissions": [
    "https://recalc.relead.com.mx/*",
    "https://web.whatsapp.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; base-uri 'self';"
  },
  "content_scripts": [
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "js": [
        "content-whatsapp.js",
        "content/bridge.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "js": [
        "content/wa-media-menu-patch-main.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "version_name": "6.3.4 caption-selector"
}
