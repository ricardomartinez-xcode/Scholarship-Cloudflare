{
  "update_url": "https://clients2.google.com/service/update2/crx",
  "manifest_version": 3,
  "name": "ReCalc Sender",
  "version": "6.2.1",
  "description": "Extensión fusionada de ReCalc para acceso Scholarship, campañas y automatización de WhatsApp Web.",
  "minimum_chrome_version": "114",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "ReCalc Sender",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "panel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "sidePanel",
    "storage",
    "tabs",
    "alarms",
    "scripting",
    "activeTab"
  ],
  "host_permissions": [
    "https://recalc.relead.com.mx/*",
    "https://web.whatsapp.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; base-uri 'self';"
  },
  "content_scripts": [
    {
      "matches": [
        "https://web.whatsapp.com/*"
      ],
      "js": [
        "content-whatsapp.js",
        "content/bridge.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
