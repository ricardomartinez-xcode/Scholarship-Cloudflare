  status              AdminImportSessionStatus @default(preview)
  source              AdminChangeSource        @default(IMPORT)
  fileName            String?
  fileChecksum        String?
  preview             Json?
  payload             Json?
  warnings            Json?
  errors              Json?
  result              Json?
  beforeSnapshot      Json?
  afterSnapshot       Json?
  summary             Json?
  createdByUserId     String?                  @db.Uuid
  createdByEmail      String?
  appliedByUserId     String?                  @db.Uuid
  appliedByEmail      String?
  appliedVersionId    String?                  @db.Uuid
  rolledBackVersionId String?                  @db.Uuid
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  appliedAt           DateTime?
  rolledBackAt        DateTime?

  @@index([module, status, createdAt], map: "admin_import_session_module_status_created_idx")
  @@index([createdByEmail, createdAt], map: "admin_import_session_creator_created_idx")
  @@map("admin_import_session")
  @@schema("recalc_admin")
}

model Organization {
  id          String   @id @default(uuid()) @db.Uuid
  displayName String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members           OrganizationMember[]
  invites           Invite[]
  announcements     AdminAnnouncement[]
  publicCtas        AdminPublicCta[]
  trainingRooms     TrainingRoom[]
  trainingPermissions TrainingRoomPermission[]
  inboxThreads      InboxThread[]

  @@map("organization")
  @@schema("recalc_admin")
}

model OrganizationMember {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @db.Uuid
  userId         String   @db.Uuid
  role           OrgRole  @default(member)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@map("organization_member")
  @@schema("recalc_admin")
}

model InboxThread {
  id            String            @id @default(uuid()) @db.Uuid
  organizationId String?          @db.Uuid
  subject       String?
  status        InboxThreadStatus @default(active)
  createdBy     String            @db.Uuid
  lastMessageAt DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  organization Organization?          @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  creator      User                   @relation("InboxThreadCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  participants InboxThreadParticipant[]
  messages     InboxMessage[]

  @@index([organizationId, updatedAt], map: "inbox_thread_org_updated_idx")
  @@index([status, lastMessageAt], map: "inbox_thread_status_last_message_idx")
  @@map("inbox_thread")
  @@schema("recalc_admin")
}

model InboxThreadParticipant {
  id         String   @id @default(uuid()) @db.Uuid
  threadId   String   @db.Uuid
  userId     String   @db.Uuid
  joinedAt   DateTime @default(now())
  lastReadAt DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  thread InboxThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@index([userId, updatedAt], map: "inbox_thread_participant_user_updated_idx")
  @@map("inbox_thread_participant")
  @@schema("recalc_admin")
}

model InboxMessage {
  id        String   @id @default(uuid()) @db.Uuid
  threadId  String   @db.Uuid
  userId    String   @db.Uuid
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  thread InboxThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt], map: "inbox_message_thread_created_idx")
  @@index([userId, createdAt], map: "inbox_message_user_created_idx")
  @@map("inbox_message")
  @@schema("recalc_admin")
}

model AcademicFee {
  id        String             @id @default(uuid()) @db.Uuid
  code      String             @unique
  concept   String
  costMxn   Int
  section   AcademicFeeSection
  isActive  Boolean            @default(true)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  campusLinks CampusAcademicFee[]

  @@map("academic_fee")
  @@schema("recalc_admin")
}

model CampusAcademicFee {
  id              String   @id @default(uuid()) @db.Uuid
  campusId        String   @db.Uuid
  academicFeeId   String   @db.Uuid
  isActive        Boolean  @default(true)
  overrideCostMxn Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  campus Campus      @relation(fields: [campusId], references: [id], onDelete: Cascade)
  fee    AcademicFee @relation(fields: [academicFeeId], references: [id], onDelete: Cascade)

  @@unique([campusId, academicFeeId])
  @@index([campusId])
  @@map("campus_academic_fee")
  @@schema("recalc_admin")
}

model ScholarshipRule {
  id                 String              @id @default(uuid()) @db.Uuid
  enrollmentType     EnrollmentType
  businessLine       BenefitBusinessLine
  modality           CanonicalModality
  plan               Int
  campusTier         String              @default("ANY")
  region             String              @default("")
  plantel            String              @default("")
  programaKey        String              @default("")
  minAverage         Decimal?            @db.Decimal(4, 2)
  maxAverage         Decimal?            @db.Decimal(4, 2)
  scholarshipPercent Decimal?            @db.Decimal(5, 2)
  discountedPriceMxn Decimal?            @db.Decimal(12, 2)
  origin             String?
  sourceVersion      String              @default("canonical")
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@unique([enrollmentType, businessLine, modality, plan, campusTier, region, plantel, programaKey, minAverage, maxAverage, sourceVersion], map: "scholarship_rule_runtime_scope_key")
  @@index([businessLine, modality, plan], map: "scholarship_rule_lookup_idx")
  @@index([sourceVersion, enrollmentType], map: "scholarship_rule_source_enrollment_idx")
  @@index([programaKey], map: "scholarship_rule_programa_key_idx")
  @@index([plantel], map: "scholarship_rule_plantel_idx")
  @@map("scholarship_rule")
  @@schema("recalc_admin")
}

model ReturnSubjectPrice {
  id                String            @id @default(uuid()) @db.Uuid
  campusId          String            @db.Uuid
  modality          CanonicalModality
  subjectCount      Int
  priceMxn          Decimal           @db.Decimal(12, 2)
  sourceVersion     String            @default("canonical")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  campus Campus @relation(fields: [campusId], references: [id], onDelete: Cascade)

  @@unique([campusId, modality, subjectCount, sourceVersion], map: "return_subject_price_runtime_key")
  @@index([campusId, modality], map: "return_subject_price_lookup_idx")
  @@map("return_subject_price")
  @@schema("recalc_admin")
}
