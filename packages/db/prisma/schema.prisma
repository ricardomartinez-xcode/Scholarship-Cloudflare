  @@index([campusId, cycle], map: "bulletin_campus_cycle_idx")
  @@map("bulletin")
  @@schema("recalc_admin")
}

model User {
  id          String    @id @default(uuid()) @db.Uuid
  authUserId  String?   @unique
  email       String    @unique
  displayName String?
  role        Role      @default(user)
  isActive    Boolean   @default(true)
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  invitesCreated             Invite[]                    @relation("InviteCreatedBy")
  invitesCancelled           Invite[]                    @relation("InviteCancelledBy")
  orgMemberships             OrganizationMember[]
  quoteSessions              QuoteSession[]
  capabilityOverrides        AdminUserCapability[]
  userCapabilities           UserCapabilityAssignment[]
  uiPreferences              AdminUiPreference[]
  ownedWhatsappTemplates     WhatsappTemplate[]          @relation("WhatsappTemplateOwner")
  authoredWhatsappTemplates  WhatsappTemplate[]          @relation("WhatsappTemplateAuthor")
  reviewedWhatsappTemplates  WhatsappTemplate[]          @relation("WhatsappTemplateReviewedBy")
  whatsappTemplatePreference WhatsappTemplatePreference?
  agendaItems                UserAgendaItem[]
  contacts                   UserContact[]
  extensionCampaigns         ExtensionCampaign[]
  googleConnection           UserGoogleConnection?
  metaWhatsappConnection     UserMetaWhatsappConnection?
  metaWhatsappMessages       MetaWhatsappMessage[]
  metaWhatsappMessageEvents  MetaWhatsappMessageEvent[]
  metaEmbeddedSignupSessions MetaEmbeddedSignupSession[]
  agendaSyncPreference       AgendaSyncPreference?
  trainingRoomsCreated       TrainingRoom[]
  trainingRoomMemberships    TrainingRoomMember[]
  trainingMessages           TrainingMessage[]
  trainingPermissions        TrainingRoomPermission[]
  trainingChatsCreated       TrainingChat[]             @relation("TrainingChatCreatedBy")
  trainingChatParticipants   TrainingChatParticipant[]
  trainingFeedbackAuthored   TrainingFeedback[]         @relation("TrainingFeedbackAuthor")
  trainingFeedbackReceived   TrainingFeedback[]         @relation("TrainingFeedbackTarget")
  inboxThreadsCreated        InboxThread[]              @relation("InboxThreadCreatedBy")
  inboxThreadParticipants    InboxThreadParticipant[]
  inboxMessages              InboxMessage[]
  pushSubscriptions          UserPushSubscription[]
  extensionSessionTokens     ExtensionSessionToken[]

  @@index([role, isActive], map: "user_role_isActive_idx")
  @@map("user")
  @@schema("recalc_admin")
}

model UserAgendaItem {
  id        String               @id @default(uuid()) @db.Uuid
  userId    String               @db.Uuid
  type      UserAgendaItemType
  status    UserAgendaItemStatus @default(abierto)
  title     String
