model Campus {
  id        String     @id @default(uuid()) @db.Uuid
  code      String     @unique
  metaKey   String     @unique
  name      String
  slug      String     @unique
  tier      String?
  kind      CampusKind
  isActive  Boolean    @default(true)
  sortOrder Int        @default(0)
  address   String?
  phone     String?
  whatsapp  String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  benefitLinks        AdminAdditionalBenefitCampus[]
  offerings           ProgramOffering[]
  contacts            DirectoryContact[]
  bulletins           Bulletin[]
  academicFees        CampusAcademicFee[]
  returnSubjectPrices ReturnSubjectPrice[]
  quoteScenarios      QuoteScenario[]

  @@map("campus")
  @@schema("recalc_admin")
}

model Program {
  id              String               @id @default(uuid()) @db.Uuid
  name            String
  nameNormalized  String               @unique
  level           String?
  category        String?
  planDriveFileId String?
  planDriveLink   String?
  planUrl         String?
  businessLine    BenefitBusinessLine?
  planPdfUrl      String?
  brochurePdfUrl  String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  offerings      ProgramOffering[]
  quoteScenarios QuoteScenario[]
  assetChecks    ProgramAssetCheck[]

  @@map("program")
  @@schema("recalc_admin")
}

model EnrollmentFormat {
  id            String   @id @default(uuid()) @db.Uuid
  title         String
  description   String?
  fileName      String?
  fileUrl       String
  fileMimeType  String?
  fileSizeBytes Int?
  sourceType    String   @default("link")
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([isActive, sortOrder], map: "enrollment_format_active_sort_idx")
  @@map("enrollment_format")
  @@schema("recalc_admin")
}

model QuoteSession {
  id           String    @id @default(uuid()) @db.Uuid
  publicId     String    @unique @default(cuid())
  ownerUserId  String    @db.Uuid
  quoteMode    String
  lastOpenedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  owner     User            @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  scenarios QuoteScenario[]
  events    BusinessEvent[]

  @@index([ownerUserId, updatedAt], map: "quote_session_owner_updated_idx")
  @@map("quote_session")
  @@schema("recalc_admin")
}

model QuoteScenario {
  id                         String              @id @default(uuid()) @db.Uuid
  quoteSessionId             String              @db.Uuid
  /// A SQL partial unique index enforces a single DRAFT per session.
  kind                       QuoteScenarioKind   @default(DRAFT)
  label                      String
  inputFingerprint           String
  inputJson                  Json
  resultJson                 Json
  enrollmentType             EnrollmentType
  businessLine               BenefitBusinessLine
  modality                   CanonicalModality
  plan                       Int
  campusId                   String?             @db.Uuid
  campusNameSnapshot         String?
  programId                  String?             @db.Uuid
  programNameSnapshot        String?
  average                    Decimal             @db.Decimal(4, 2)
  subjectCount               Int?
  extraChargeAmount          Decimal             @default(0) @db.Decimal(12, 2)
  basePriceMxn               Decimal             @db.Decimal(12, 2)
  scholarshipPercent         Decimal             @db.Decimal(5, 2)
  scholarshipAmountMxn       Decimal             @db.Decimal(12, 2)
  additionalBenefitPercent   Decimal             @db.Decimal(5, 2)
  additionalBenefitAmountMxn Decimal             @db.Decimal(12, 2)
  firstPaymentAmountMxn      Decimal             @default(0) @db.Decimal(12, 2)
  subtotalMxn                Decimal             @db.Decimal(12, 2)
  totalMxn                   Decimal             @db.Decimal(12, 2)
  sinAccessToScholarship     Boolean             @default(false)
  createdAt                  DateTime            @default(now())
  updatedAt                  DateTime            @updatedAt

  quoteSession QuoteSession    @relation(fields: [quoteSessionId], references: [id], onDelete: Cascade)
  campus       Campus?         @relation(fields: [campusId], references: [id], onDelete: SetNull)
  program      Program?        @relation(fields: [programId], references: [id], onDelete: SetNull)
  events       BusinessEvent[]

  @@index([quoteSessionId, kind, updatedAt], map: "quote_scenario_session_kind_updated_idx")
  @@index([campusId, updatedAt], map: "quote_scenario_campus_updated_idx")
  @@index([programId, updatedAt], map: "quote_scenario_program_updated_idx")
  @@index([inputFingerprint], map: "quote_scenario_fingerprint_idx")
  @@map("quote_scenario")
  @@schema("recalc_admin")
}

model BusinessEvent {
  id              String            @id @default(uuid()) @db.Uuid
  type            BusinessEventType
  userId          String?           @db.Uuid
  quoteSessionId  String?           @db.Uuid
  quoteScenarioId String?           @db.Uuid
  subjectType     String?
  subjectId       String?
  metadata        Json?
  createdAt       DateTime          @default(now())

  quoteSession  QuoteSession?  @relation(fields: [quoteSessionId], references: [id], onDelete: Cascade)
  quoteScenario QuoteScenario? @relation(fields: [quoteScenarioId], references: [id], onDelete: Cascade)

  @@index([type, createdAt], map: "business_event_type_created_idx")
  @@index([quoteSessionId, createdAt], map: "business_event_session_created_idx")
  @@index([quoteScenarioId, createdAt], map: "business_event_scenario_created_idx")
  @@index([subjectType, subjectId, createdAt], map: "business_event_subject_created_idx")
  @@index([userId, createdAt], map: "business_event_user_created_idx")
  @@map("business_event")
  @@schema("recalc_admin")
}

model ProgramAssetCheck {
  id          String             @id @default(uuid()) @db.Uuid
  programId   String             @db.Uuid
  assetType   ProgramAssetType
  url         String
  status      ProgramAssetStatus
  httpStatus  Int?
  contentType String?
  error       String?
  checkedAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([programId, assetType], map: "program_asset_check_program_asset_type_key")
  @@index([status, checkedAt], map: "program_asset_check_status_checked_idx")
  @@map("program_asset_check")
  @@schema("recalc_admin")
}

model ProgramOffering {
  id                   String                  @id @default(uuid()) @db.Uuid
  campusId             String                  @db.Uuid
  programId            String                  @db.Uuid
  cycle                String
  track                String?
  delivery             ProgramOfferingDelivery @default(CAMPUS)
  escolarizado         Boolean                 @default(false)
  ejecutivo            Boolean                 @default(false)
  escolarizadoSchedule String?
  ejecutivoSchedule    String?
  lineOfBusiness       String?
  pricingPlans         Int[]                   @default([])
  isActive             Boolean                 @default(true)
  archivedAt           DateTime?
  archivedReason       String?
  updatedBy            String?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  campus  Campus  @relation(fields: [campusId], references: [id], onDelete: Cascade)
  program Program @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@unique([campusId, programId, cycle])
  @@index([campusId, cycle])
  @@index([cycle, isActive])
  @@map("program_offering")
  @@schema("recalc_admin")
}

model DirectoryContact {
  id           String   @id @default(uuid()) @db.Uuid
