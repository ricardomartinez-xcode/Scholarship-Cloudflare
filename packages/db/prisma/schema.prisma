model ExtensionCampaign {
  id              String    @id @default(uuid()) @db.Uuid
  ownerUserId     String    @db.Uuid
  campaignName    String
  channel         String    @default("whatsapp_web")
  status          String    @default("queued")
  scheduleAt      DateTime?
  batchSize       Int       @default(25)
  messageTemplate String?
  messageDelayMs  Int       @default(4000)
  mediaUrl        String?
  notes           String?
  meta            Json?
  completedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  owner      User                         @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  recipients ExtensionCampaignRecipient[]

  @@index([ownerUserId, updatedAt], map: "extension_campaign_owner_updated_idx")
  @@index([status, scheduleAt], map: "extension_campaign_status_schedule_idx")
  @@map("extension_campaign")
  @@schema("recalc_admin")
}

model ExtensionCampaignRecipient {
  id           String    @id @default(uuid()) @db.Uuid
  campaignId   String    @db.Uuid
  externalKey  String?
  contactValue String
  contactName  String?
  payload      Json?
  scheduledFor DateTime?
  status       String    @default("queued")
  attemptedAt  DateTime?
  sentAt       DateTime?
  lastError    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  campaign ExtensionCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, contactValue], map: "extension_campaign_recipient_campaign_contact_key")
  @@index([campaignId, status, scheduledFor], map: "extension_campaign_recipient_claim_idx")
  @@map("extension_campaign_recipient")
  @@schema("recalc_admin")
}


model ExtensionSessionToken {
  id               String    @id @default(uuid()) @db.Uuid
  userId           String    @db.Uuid
  tokenHash        String    @unique
  scope            String    @default("extension:default")
  client           String?
  extensionVersion String?
  userAgent        String?
  expiresAt        DateTime
  revokedAt        DateTime?
  lastUsedAt       DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt, expiresAt], map: "extension_session_token_user_valid_idx")
  @@index([expiresAt], map: "extension_session_token_expires_idx")
  @@map("extension_session_token")
  @@schema("recalc_admin")
}

