  userId                      String    @unique @db.Uuid
  provider                    String    @default("meta_whatsapp")
  encryptedMetaAccessToken    String?
  encryptedSystemUserToken    String?
  graphApiVersion             String    @default("v25.0")
  wabaId                      String?
  phoneNumberId               String?
  businessAccountId           String?
  businessManagerId           String?
  businessName                String?
  wabaName                    String?
  wabaCurrency                String?
