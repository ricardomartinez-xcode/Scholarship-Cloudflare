  dueAt     DateTime?
  sortOrder Int                  @default(0)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt

  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  externalSyncs AgendaExternalSync[]

  @@index([userId, status, updatedAt], map: "user_agenda_item_user_status_updated_idx")
  @@index([userId, type, updatedAt], map: "user_agenda_item_user_type_updated_idx")
  @@map("user_agenda_item")
  @@schema("recalc_admin")
}

model UserContact {
  id                           String    @id @default(uuid()) @db.Uuid
  ownerUserId                  String    @db.Uuid
  contactName                  String
  phone                        String
  normalizedPhone              String
  waId                         String?
  bsuid                        String?
  parentBsuid                  String?
  whatsappUsername             String?
  profilePictureUrl            String?
  profileSource                String?
  lastProfileSyncAt            DateTime?
  lastIdentitySyncAt           DateTime?
  email                        String?
  tags                         Json?
  personalData                 String?
  notes                        String?
  lastWhatsappMessageAt        DateTime?
  lastWhatsappMessageText      String?
  campaignMessageCount         Int       @default(0)
