// ============================================================================
// TRAINING / CAPACITACION MODELS
// ============================================================================
// These models support the new /capacitacion/rolplay feature.
// They integrate with Supabase Realtime for real-time chat and presence.
// Persistence is in Neon (Prisma), Realtime layer is Supabase.

model TrainingRoom {
  id              String                   @id @default(uuid()) @db.Uuid
  organizationId  String                   @db.Uuid
  name            String
  description     String?
  scenario        String? // e.g., "customer_service", "sales_b2b"
  visibility      TrainingRoomVisibility   @default(org)
  createdBy       String                   @db.Uuid
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt

  // Relations
  organization    Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator         User                     @relation(fields: [createdBy], references: [id], onDelete: Restrict)
  members         TrainingRoomMember[]
  messages        TrainingMessage[]
  chats           TrainingChat[]
  feedbackEntries TrainingFeedback[]

  @@index([organizationId])
  @@index([createdBy])
  @@index([createdAt])
  @@schema("recalc_admin")
}

enum TrainingRoomVisibility {
  private // Only invited members
  org     // All org members
  public  // All platform users

  @@schema("recalc_admin")
}

model TrainingRoomMember {
  id               String           @id @default(uuid()) @db.Uuid
  roomId           String           @db.Uuid
  userId           String           @db.Uuid
  role             TrainingRoomRole @default(participant)
  accessRole       TrainingAccessRole @default(user)
  isAnonymous      Boolean          @default(true)
  anonymousAlias   String? // e.g., "Participante 01", "Asesor anónimo"
  joinedAt         DateTime         @default(now())
  leftAt           DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relations
  room             TrainingRoom     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  chatParticipants TrainingChatParticipant[]

  @@unique([roomId, userId])
  @@index([roomId])
  @@index([userId])
  @@index([joinedAt])
  @@schema("recalc_admin")
}

enum TrainingRoomRole {
  participant
  trainer
  facilitator

  @@schema("recalc_admin")
}

model TrainingMessage {
  id        String   @id @default(uuid()) @db.Uuid
  roomId    String   @db.Uuid
  chatId    String?  @db.Uuid
  userId    String   @db.Uuid
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  room      TrainingRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  chat      TrainingChat? @relation(fields: [chatId], references: [id], onDelete: SetNull)
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([chatId])
  @@index([userId])
  @@index([createdAt])
  @@schema("recalc_admin")
}

model TrainingChat {
  id            String             @id @default(uuid()) @db.Uuid
  roomId        String             @db.Uuid
  title         String?
  status        TrainingChatStatus @default(open)
  createdBy     String             @db.Uuid
  closedAt      DateTime?
  lastMessageAt DateTime?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  room            TrainingRoom            @relation(fields: [roomId], references: [id], onDelete: Cascade)
  creator         User                    @relation("TrainingChatCreatedBy", fields: [createdBy], references: [id], onDelete: Restrict)
  participants    TrainingChatParticipant[]
  messages        TrainingMessage[]
  feedbackEntries TrainingFeedback[]

  @@index([roomId, updatedAt], map: "training_chat_room_updated_idx")
  @@index([status, lastMessageAt], map: "training_chat_status_last_message_idx")
  @@map("training_chat")
  @@schema("recalc_admin")
}

model TrainingChatParticipant {
  id           String             @id @default(uuid()) @db.Uuid
  chatId       String             @db.Uuid
  roomMemberId String?            @db.Uuid
  userId       String             @db.Uuid
  role         TrainingAccessRole @default(user)
  joinedAt     DateTime           @default(now())
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  chat       TrainingChat       @relation(fields: [chatId], references: [id], onDelete: Cascade)
  roomMember TrainingRoomMember? @relation(fields: [roomMemberId], references: [id], onDelete: SetNull)
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([roomMemberId], map: "training_chat_participant_room_member_idx")
  @@index([userId, joinedAt], map: "training_chat_participant_user_joined_idx")
  @@map("training_chat_participant")
  @@schema("recalc_admin")
}

model TrainingFeedback {
  id           String   @id @default(uuid()) @db.Uuid
  roomId       String   @db.Uuid
  chatId       String   @db.Uuid
  authorUserId String   @db.Uuid
  targetUserId String   @db.Uuid
  rating       Int?
  summary      String
  strengths    String?
  improvements String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  room       TrainingRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  chat       TrainingChat @relation(fields: [chatId], references: [id], onDelete: Cascade)
  authorUser User         @relation("TrainingFeedbackAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)
  targetUser User         @relation("TrainingFeedbackTarget", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt], map: "training_feedback_chat_created_idx")
  @@index([targetUserId, createdAt], map: "training_feedback_target_created_idx")
  @@map("training_feedback")
  @@schema("recalc_admin")
}

