}

model DirectoryContactMethod {
  id                 String                     @id @default(uuid()) @db.Uuid
  directoryContactId String                     @db.Uuid
  type               DirectoryContactMethodType
  value              String
  normalizedValue    String
  isPrimary          Boolean                    @default(false)
  sortOrder          Int                        @default(0)
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  directoryContact DirectoryContact @relation(fields: [directoryContactId], references: [id], onDelete: Cascade)

  @@unique([directoryContactId, type, normalizedValue], map: "directory_contact_method_unique_value_idx")
  @@index([directoryContactId, sortOrder], map: "directory_contact_method_contact_sort_idx")
  @@index([type, normalizedValue], map: "directory_contact_method_type_normalized_idx")
  @@map("directory_contact_method")
  @@schema("recalc_admin")
}

model Bulletin {
  id        String   @id @default(uuid()) @db.Uuid
  campusId  String   @db.Uuid
  cycle     String?
  fileName  String
  filePath  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

