{
  "name": "relead-recalc-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@11.12.1",
  "scripts": {
    "dev": "npm --workspace @relead/web run dev",
    "build": "npm run build:next",
    "build:next": "npm --workspace @relead/web run build",
    "d1:export-core": "tsx scripts/export-cloudflare-d1-core.ts",
    "migration:export-d1": "tsx scripts/export-d1-data.ts --dry-run",
    "migration:transform-d1": "tsx scripts/transform-d1-to-postgres.ts --dry-run",
    "migration:import-supabase": "tsx scripts/import-supabase-data.ts --dry-run",
    "migration:validate-data": "tsx scripts/validate-migrated-data.ts",
    "migration:migrate-storage": "tsx scripts/migrate-r2-to-supabase-storage.ts --dry-run",
    "check": "npm run lint && npm run typecheck && npm test",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "vercel-build": "sh scripts/vercel-build.sh",
    "start": "npm --workspace @relead/web run start",
    "lint": "eslint apps packages scripts --max-warnings=0",
    "test:e2e": "playwright test -c playwright.config.ts",
    "test:e2e:whatsapp-auth": "playwright test apps/web/tests/e2e/whatsapp-extension-caption.spec.ts",
    "test:e2e:whatsapp-extension": "playwright test apps/web/tests/e2e/whatsapp-extension-caption.spec.ts",
    "test:e2e:visual": "playwright test tests/e2e/visual-regression.spec.ts",
    "test:e2e:critical": "playwright test tests/e2e/admin-import.spec.ts tests/e2e/admin-ui.spec.ts tests/e2e/admin-critical.spec.ts tests/e2e/cost-flow.spec.ts",
    "release:gate": "tsx scripts/release-gate.ts",
    "promote": "powershell -ExecutionPolicy Bypass -File scripts/promote.ps1",
    "repo:large-files": "node scripts/report-large-source-files.mjs",
    "seed:neon": "node scripts/seed_neon.js",
    "verify:neon": "node scripts/verify_neon.js",
    "neon:auth:webhook": "node scripts/configure-neon-auth-webhook.mjs",
    "neon:auth:oauth": "node scripts/configure-neon-auth-oauth-provider.mjs",
    "postinstall": "prisma generate --schema packages/db/prisma/schema.prisma",
    "db:migrate:dev": "prisma migrate dev --schema packages/db/prisma/schema.prisma",
    "db:migrate:deploy": "prisma migrate deploy --schema packages/db/prisma/schema.prisma",
    "admin:bootstrap": "node scripts/bootstrap-admin.js",
    "campus:seed": "node scripts/seed-campuses.js",
    "extension:package": "powershell -ExecutionPolicy Bypass -File scripts/package-chrome-extension.ps1",
    "extension:sync": "node scripts/sync-extension-variants.mjs",
    "extension:verify": "node scripts/verify-extension-variants.mjs",
    "import:output": "tsx scripts/import-output.ts",
    "test": "vitest run -c vitest.config.ts",
    "lint:all": "npm run lint",
    "typecheck:all": "npm run typecheck",
    "build:all": "npm run build",
    "turbo": "npx turbo@2.9.6",
    "turbo:build": "npx turbo@2.9.6 run build //#build",
    "turbo:lint": "npx turbo@2.9.6 run lint //#lint",
    "turbo:typecheck": "npx turbo@2.9.6 run typecheck //#typecheck",
    "turbo:test": "npx turbo@2.9.6 run test //#test",
    "turbo:check": "npx turbo@2.9.6 run lint typecheck build //#lint //#typecheck //#build",
    "db:generate": "prisma generate --schema packages/db/prisma/schema.prisma",
    "db:validate": "prisma validate --schema packages/db/prisma/schema.prisma",
    "verify:structure": "node scripts/verify-monorepo-structure.mjs"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@opennextjs/cloudflare": "^1.20.1",
    "@prisma/client": "^6.19.2",
    "@prisma/extension-accelerate": "^3.0.1",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@sentry/nextjs": "^10.42.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.103.2",
    "exceljs": "^4.4.0",
    "geist": "^1.7.0",
    "html-to-image": "^1.11.13",
    "next": "^16.2.6",
    "nodemailer": "^9.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "server-only": "^0.0.1",
    "web-push": "^3.6.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/nodemailer": "^7.0.9",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/web-push": "^3.6.4",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "prisma": "^6.19.2",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "5.9.3",
    "vitest": "^4.1.9",
    "wrangler": "^4.105.0"
  },
  "overrides": {
    "@better-auth/passkey": "1.6.20",
    "better-auth": "1.6.20",
    "postcss": "^8.5.15",
    "tmp": "^0.2.7",
    "uuid": "11.1.1"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
