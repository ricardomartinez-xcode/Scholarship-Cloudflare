{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm ci --foreground-scripts",
  "outputDirectory": "apps/web/.next",
  "git": {
    "deploymentEnabled": {
      "fix/*": false,
      "chore/*": false,
      "docs/*": false,
      "refactor/*": false,
      "test/*": false,
      "wip/*": false,
      "internal-*": false
    }
  }
}
