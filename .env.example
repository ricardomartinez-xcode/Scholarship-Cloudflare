# Public browser variables
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only database variables for Supabase PostgreSQL
DATABASE_URL=
DIRECT_URL=

# Optional server-only key for admin-only maintenance scripts.
# Never expose this with a NEXT_PUBLIC_ prefix.
SUPABASE_SERVICE_ROLE_KEY=

# Optional local switch for legacy D1-named routes backed by PostgreSQL.
# Vercel sets VERCEL=1 automatically, so this is mainly for local smoke tests.
POSTGRES_COMPAT_RUNTIME=
